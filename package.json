{
  "name": "projectflow",
  "version": "1.0.0",
  "main": "electron/main.js",

  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",

    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",

    "electron:dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5000/api/health http://localhost:5173 && electron .\"",

    "build:frontend": "cd frontend && npm run build",

    "electron:build": "npm run build:frontend && electron-builder build --publish never",

    "start": "cross-env NODE_ENV=production electron .",

    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },

  "build": {
    "appId": "com.projectflow.app",
    "productName": "ProjectFlow",

    "directories": {
      "output": "dist-electron"
    },

    "files": [
      "electron/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      }
    ],

    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },

    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.productivity"
    },

    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    }
  },

  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
      "wait-on": "^7.2.0"
  }
}